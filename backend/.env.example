APP_NAME=RecruitFlow Agent
APP_ENV=dev
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=recruitflow_agent

# Agent provider: mock / openai / qwen / deepseek
LLM_PROVIDER=mock

# OpenAI-compatible LLM config
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30
LLM_FALLBACK_TO_MOCK=true
